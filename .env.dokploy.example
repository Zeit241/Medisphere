# Скопируйте переменные во вкладку Environment в Dokploy (Compose → Environment).
# Dokploy сохранит их в .env рядом с docker-compose.dokploy.yml.

# === PostgreSQL ===
POSTGRES_USER=clinic_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=clinic_db

# === Directus ===
DIRECTUS_SECRET=change-me-64-chars-random-secret-for-directus-jwt-signing
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me-admin-password
DIRECTUS_PUBLIC_URL=https://cms.example.com
DIRECTUS_TOKEN=your-static-token-from-directus-settings

# CORS: домены админки, лендинга и локальной разработки (через запятую)
CORS_ORIGIN=https://admin.example.com,https://clinic.example.com

# === Backend (Spring Boot) ===
JWT_SECRET=change-me-at-least-256-bits-random-secret-for-jwt

# === Landing (Next.js) ===
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars
NEXTAUTH_URL=https://clinic.example.com
NEXT_PUBLIC_SITE_URL=https://clinic.example.com
NEXT_PUBLIC_DIRECTUS_URL=https://cms.example.com

# === Frontend admin (Vite + nginx) ===
VITE_API_URL=https://api.example.com
VITE_DIRECTUS_URL=/__directus
VITE_DIRECTUS_PUBLIC_URL=https://cms.example.com

# === SMTP (опционально) ===
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

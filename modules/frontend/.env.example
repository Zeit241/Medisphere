# Загрузка POST /files через proxy (без CORS)
VITE_DIRECTUS_URL=/__directus

# Превью <img src>: абсолютный адрес Directus + access_token в query (иначе /assets даёт 403)
VITE_DIRECTUS_PUBLIC_URL=http://localhost:8055

# Static token (create на files; для чтения превью через access_token)
VITE_DIRECTUS_STATIC_TOKEN=
